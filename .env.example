# Copy to .env.local and fill from Firebase Console → Project settings → Your apps → Firebase SDK snippet (config).
#
# GitHub Pages: create the same variables as repository Secrets (Settings → Secrets and variables → Actions),
# using these exact names, so the "Deploy to GitHub Pages" workflow can embed them at build time.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
